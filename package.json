{
  "name": "onenote-ribbon",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit && node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "dev:launch-obsidian": "node scripts/run-debug.mjs",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "tsx scripts/e2e/run-e2e.ts --launch --code-coverage --coverage-html --coverage-report",
    "run:e2e": "tsx scripts/e2e/run-e2e.ts --launch --code-coverage --coverage-html --coverage-report",
    "test:e2e:launch": "tsx scripts/e2e/run-e2e.ts --launch --code-coverage --coverage-html --coverage-report",
    "test:e2e:home": "tsx scripts/e2e/run-e2e.ts --suite home,home-combinations,basic-text,clipboard,styles,tags,email,navigate --code-coverage --coverage-html --coverage-report",
    "test:e2e:coverage": "tsx scripts/e2e/run-e2e.ts --launch --suite home,home-combinations,basic-text,clipboard,styles,tags,email,navigate,edge-cases,ribbon-components --code-coverage --coverage-html --coverage-report",
    "test:e2e:coverage:check": "tsx scripts/e2e/run-e2e.ts --launch --code-coverage --coverage-html --coverage-report --coverage-threshold 80",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "obsidian": "latest",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.20.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.58.2"
  }
}
