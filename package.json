{
  "name": "onenote-ribbon",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "dev:launch-obsidian": "node scripts/run-debug.mjs",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "tsx scripts/e2e/run-e2e.ts --launch --coverage",
    "run:e2e": "tsx scripts/e2e/run-e2e.ts --launch --coverage --coverage-scope styling-engine",
    "test:e2e:launch": "tsx scripts/e2e/run-e2e.ts --launch",
    "test:e2e:home": "tsx scripts/e2e/run-e2e.ts --suite home,home-combinations,basic-text,clipboard,styles,tags,email,navigate",
    "test:e2e:insert": "tsx scripts/e2e/run-e2e.ts --suite insert,insert-combinations,tables,files,images,links,timestamp,blocks,symbols"
  },
  "dependencies": {
    "obsidian": "latest",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.20.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^29.0.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.3.0"
  }
}
